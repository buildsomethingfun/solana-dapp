<font-family
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <font
        android:font="@font/dm_sans_light"
        android:fontStyle="normal"
        android:fontVariationSettings='"wght" 300'
        android:fontWeight="300"

        app:font="@font/dm_sans_light"
        app:fontStyle="normal"
        app:fontVariationSettings='"wght" 300'
        app:fontWeight="300" />

    <font
        android:font="@font/dm_sans_italic"
        android:fontStyle="italic"
        android:fontVariationSettings='"wght" 400'
        android:fontWeight="400"

        app:font="@font/dm_sans_italic"
        app:fontStyle="italic"
        app:fontVariationSettings='"wght" 400'
        app:fontWeight="400" />

    <font
        android:font="@font/dm_sans_regular"
        android:fontStyle="normal"
        android:fontVariationSettings='"wght" 400'
        android:fontWeight="400"

        app:font="@font/dm_sans_regular"
        app:fontStyle="normal"
        app:fontVariationSettings='"wght" 400'
        app:fontWeight="400" />

    <font
        android:font="@font/dm_sans_medium"
        android:fontStyle="normal"
        android:fontVariationSettings='"wght" 500'
        android:fontWeight="500"

        app:font="@font/dm_sans_medium"
        app:fontStyle="normal"
        app:fontVariationSettings='"wght" 500'
        app:fontWeight="500" />

    <font
        android:font="@font/dm_sans_semibold"
        android:fontStyle="normal"
        android:fontVariationSettings='"wght" 600'
        android:fontWeight="600"

        app:font="@font/dm_sans_semibold"
        app:fontStyle="normal"
        app:fontVariationSettings='"wght" 600'
        app:fontWeight="600" />

    <font
        android:font="@font/dm_sans_bold"
        android:fontStyle="normal"
        android:fontVariationSettings='"wght" 700'
        android:fontWeight="700"

        app:font="@font/dm_sans_bold"
        app:fontStyle="normal"
        app:fontVariationSettings='"wght" 700'
        app:fontWeight="700" />

    <font
        android:font="@font/dm_sans_extrabold"
        android:fontStyle="normal"
        android:fontVariationSettings='"wght" 800'
        android:fontWeight="800"

        app:font="@font/dm_sans_extrabold"
        app:fontStyle="normal"
        app:fontVariationSettings='"wght" 800'
        app:fontWeight="800" />

    <font
        android:font="@font/dm_sans_black"
        android:fontStyle="normal"
        android:fontVariationSettings='"wght" 900'
        android:fontWeight="900"

        app:font="@font/dm_sans_black"
        app:fontStyle="normal"
        app:fontVariationSettings='"wght" 900'
        app:fontWeight="900" />

</font-family>
